<style>
  /* Palette mirrors .claude/skills/prospect-evaluation/templates/single-report.html (prospect-evaluation aesthetic) */
  :root {
    --bg: #0f1419;
    --panel: #171d26;
    --panel-2: #1f2733;
    --text: #e7ecf3;
    --muted: #8a97ab;
    --border: #2a3342;
    --accent: #5aa7ff;
    --pass: #2fbf71;
    --fail: #e74c3c;
    --warn: #f5a623;
    --badge: #0b1019;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: var(--bg); color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                 "Helvetica Neue", Arial, sans-serif;
    line-height: 1.55; font-size: 15px;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .container { max-width: 1280px; margin: 0 auto; padding: 24px; }

  /* Header banner — matches single-report.html header.banner */
  header.banner {
    background: linear-gradient(180deg, #1a2332 0%, #0f1419 100%);
    border: 1px solid var(--border); border-radius: 14px;
    padding: 22px 26px; margin-bottom: 24px;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 16px;
  }
  header.banner h1 { margin: 0 0 4px 0; font-size: 26px; }
  header.banner .meta { color: var(--muted); font-size: 13px; }

  .stats-row { display: flex; gap: 12px; flex-wrap: wrap; }
  .stat-card {
    background: var(--badge); border: 1px solid var(--border);
    border-radius: 12px; padding: 12px 18px; text-align: center; min-width: 110px;
  }
  .stat-card .num { font-size: 30px; font-weight: 800; color: var(--accent); line-height: 1; }
  .stat-card .label {
    font-size: 11px; color: var(--muted); letter-spacing: .08em;
    text-transform: uppercase; margin-top: 4px;
  }

  /* Sections — matches single-report.html section */
  section {
    background: var(--panel); border: 1px solid var(--border);
    border-radius: 12px; padding: 20px 24px; margin-bottom: 18px;
  }
  section h2 {
    margin: 0 0 14px 0; font-size: 18px; color: var(--text);
    padding-bottom: 10px; border-bottom: 1px solid var(--border);
  }
  section h2 .badge {
    display: inline-block; padding: 2px 10px; border-radius: 999px;
    font-size: 12px; font-weight: 700; margin-left: 8px;
    background: rgba(90,167,255,.15); color: var(--accent);
    border: 1px solid rgba(90,167,255,.3);
  }
  section h3 { font-size: 15px; color: var(--text); margin: 18px 0 8px; }
  section p, section li { color: #cbd3df; }

  /* Tables — matches single-report.html */
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  th, td {
    text-align: left; padding: 9px 10px;
    border-bottom: 1px solid var(--border); vertical-align: top;
  }
  th {
    color: var(--muted); font-weight: 600; font-size: 12px;
    letter-spacing: .04em; text-transform: uppercase; background: var(--panel-2);
  }
  tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: rgba(90,167,255,.04); }

  /* Score cell + chips */
  .score { font-weight: 800; font-size: 16px; }
  .score.high { color: var(--pass); }
  .score.mid  { color: var(--accent); }
  .score.low  { color: var(--fail); }

  .chip {
    display: inline-block; padding: 2px 9px; border-radius: 999px;
    font-size: 12px; font-weight: 700; margin-left: 6px;
  }
  .chip.price-drop {
    background: rgba(245,166,35,.15); color: var(--warn);
    border: 1px solid rgba(245,166,35,.4);
  }
  .chip.manual {
    background: rgba(90,167,255,.15); color: var(--accent);
    border: 1px solid rgba(90,167,255,.3);
  }

  /* Run-summary grid */
  .summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 768px) { .summary-grid { grid-template-columns: 1fr; } }
  .summary-card {
    background: var(--panel-2); border: 1px solid var(--border);
    border-radius: 8px; padding: 14px;
  }
  .summary-card h3 {
    font-size: 13px; color: var(--muted); letter-spacing: .06em;
    text-transform: uppercase; margin: 0 0 10px 0;
  }
  .summary-card ul { list-style: none; }
  .summary-card li { padding: 3px 0; font-size: 14px; }
  .summary-card li strong { color: var(--text); }

  .empty-state {
    color: var(--muted); font-style: italic; text-align: center; padding: 22px;
  }

  footer { color: var(--muted); font-size: 12px; text-align: center; padding: 16px; }
  footer code { color: var(--text); }
</style>
</head>
