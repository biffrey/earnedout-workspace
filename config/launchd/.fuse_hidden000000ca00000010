<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.earnedout.offmarket-search</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/biffreybraxton/published-listing-search/run-offmarket-search.sh</string>
    </array>

    <!-- ONE-TIME run: Saturday 2026-05-23 at 10:00 local (Weekday 6 = Saturday).
         Temporarily changed from the standing weekly Monday 06:00 schedule for a
         single run; bootout the agent again once this run completes. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>6</integer>
        <key>Hour</key>
        <integer>10</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Do not run when the agent is (re)loaded — only on the calendar trigger. -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/biffreybraxton/published-listing-search/output/logs/launchd.offmarket-search.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/biffreybraxton/published-listing-search/output/logs/launchd.offmarket-search.err.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
